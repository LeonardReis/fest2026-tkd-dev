rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: email (string), role (string), academyId (string), displayName (string)
    //
    // Collection: academies
    // Fields: name (string), coach (string), master (string), contact (string), createdBy (string)
    //
    // Collection: athletes
    // Fields: name (string), birthDate (string), gender (string), belt (string), weight (number), academyId (string), createdBy (string)
    //
    // Collection: registrations
    // Fields: athleteId (string), academyId (string), category (string), status (string), paymentStatus (string), createdAt (string)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email in ["leo@laravitoria.com", "tauyllin.edfisica@hotmail.com", "tauyllin.tkd@gmail.com", "carloswalesko@gmail.com"] ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }

    function isMaster() {
      return isAuthenticated() && 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'master');
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // Validators
    function isValidUser(data) {
      return data.email is string && (data.role == 'admin' || data.role == 'master');
    }

    function isValidAcademy(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.coach is string && data.coach.size() > 0 &&
             data.master is string && data.master.size() > 0 &&
             data.createdBy == request.auth.uid &&
             hasOnlyAllowedFields(['name', 'coach', 'master', 'contact', 'logo', 'createdBy']);
    }

    function isValidAthlete(data) {
      return data.name is string && data.name.size() > 0 &&
             data.birthYear is number &&
             data.gender in ['M', 'F'] &&
             data.belt is string &&
             data.weight is number &&
             data.academyId is string &&
             data.createdBy == request.auth.uid &&
             hasOnlyAllowedFields(['name', 'birthYear', 'gender', 'belt', 'weight', 'academyId', 'createdBy', 'avatar']);
    }

    function isValidRegistration(data) {
      return data.athleteId is string &&
             data.academyId is string &&
             data.categories is list;
    }

    // Rules
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId);
      allow update: if (isOwner(userId) && (resource.data.role == null || request.resource.data.role == resource.data.role)) || isAdmin();
    }

    match /academies/{academyId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidAcademy(request.resource.data);
      allow update: if isAdmin() || (isAuthenticated() && resource.data.createdBy == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /athletes/{athleteId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidAthlete(request.resource.data) && (isAdmin() || (isMaster() && request.resource.data.academyId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.academyId));
      allow update: if isAdmin() || (isAuthenticated() && resource.data.createdBy == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /registrations/{regId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidRegistration(request.resource.data) && 
                      (isAdmin() || isMaster());
      allow update: if isAdmin() || (isAuthenticated() && (resource.data.academyId != null && get(/databases/$(database)/documents/academies/$(resource.data.academyId)).data.createdBy == request.auth.uid));
      allow delete: if isAdmin() || (isAuthenticated() && (resource.data.academyId != null && get(/databases/$(database)/documents/academies/$(resource.data.academyId)).data.createdBy == request.auth.uid));
    }

    match /receipts/{receiptId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.academyId is string && request.resource.data.receiptData is string && request.resource.data.receiptData.size() < 800000;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /mail/{mailId} {
      allow create: if isAuthenticated();
      allow read: if false;
      allow update, delete: if false;
    }

    match /matches/{matchId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }
  }
}
