rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: email (string), role (string), academyId (string), displayName (string)
    //
    // Collection: academies
    // Fields: name (string), coach (string), master (string), contact (string), createdBy (string)
    //
    // Collection: athletes
    // Fields: name (string), birthDate (string), gender (string), belt (string), weight (number), academyId (string), createdBy (string)
    //
    // Collection: registrations
    // Fields: athleteId (string), academyId (string), category (string), status (string), paymentStatus (string), createdAt (string)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "leo@laravitoria.com" && request.auth.token.email_verified == true) ||
         (request.auth.token.email == "carloswalesko@gmail.com" && request.auth.token.email_verified == true));
    }

    function isMaster() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'master';
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // Validators
    function isValidUser(data) {
      return data.email is string && data.role in ['admin', 'master'];
    }

    function isValidAcademy(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.coach is string && data.coach.size() > 0 &&
             data.master is string && data.master.size() > 0 &&
             data.createdBy == request.auth.uid;
    }

    function isValidAthlete(data) {
      return data.name is string && data.name.size() > 0 &&
             data.birthDate is string &&
             data.gender in ['M', 'F'] &&
             data.belt is string &&
             data.weight is number &&
             data.academyId is string &&
             data.createdBy == request.auth.uid;
    }

    function isValidRegistration(data) {
      return data.athleteId is string &&
             data.academyId is string &&
             data.categories is list &&
             data.categories.size() > 0 &&
             data.status in ['Pendente', 'Confirmado', 'Cancelado'] &&
             data.paymentStatus in ['Pendente', 'Pago', 'Em Análise'];
    }

    // Rules
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.role == 'master' || isAdmin());
      allow update: if (isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin();
    }

    match /academies/{academyId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidAcademy(request.resource.data);
      allow update: if isAdmin() || (isAuthenticated() && resource.data.createdBy == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /athletes/{athleteId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidAthlete(request.resource.data);
      allow update: if isAdmin() || (isAuthenticated() && resource.data.createdBy == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /registrations/{regId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidRegistration(request.resource.data);
      allow update: if isAdmin() || (isAuthenticated() && get(/databases/$(database)/documents/academies/$(resource.data.academyId)).data.createdBy == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /receipts/{receiptId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.academyId is string && request.resource.data.receiptData is string && request.resource.data.receiptData.size() < 800000;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /mail/{mailId} {
      allow create: if isAuthenticated();
      allow read: if false;
      allow update, delete: if false;
    }
  }
}
